NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=OpenCollab.id

# Postgres (docker-compose defaults shown)
DATABASE_URL=postgresql://kolfinder:kolfinder@localhost:5432/kolfinder

# Auth.js (NextAuth v5) — Credentials provider + JWT sessions. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth ("Continue with Google") — optional. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials (authorized redirect URI:
# <NEXT_PUBLIC_APP_URL>/api/auth/callback/google). Leave both empty to omit the provider
# entirely — the app runs fine on Credentials-only auth without it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" only once the two secrets above are set, so the client-side "Continue with
# Google" buttons know the provider is actually configured.
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED=false

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Shared secret used to sign requests between the web app and the worker
WORKER_SHARED_SECRET=change-me-dev-secret

# AI layer (query interpretation, niche classification, ranking explanations)
# Leave AI_API_KEY empty to fall back to deterministic templates.
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-sonnet-5

# Scraper source: "browser" (default, Playwright against public TikTok pages) or "apify"
# (clockworks/tiktok-scraper actor via Apify — no local Chromium needed).
SCRAPER_SOURCE=browser

# Required only when SCRAPER_SOURCE=apify. Get a token from https://console.apify.com/settings/integrations
APIFY_API_TOKEN=
APIFY_TIKTOK_ACTOR_ID=GdWCkxBtKWOsKjdch

# Scraper tuning
SCRAPER_MAX_CONCURRENCY=2
SCRAPER_NAVIGATION_TIMEOUT_MS=30000
SCRAPER_PROFILE_LIMIT=30
SCRAPER_VIDEO_LIMIT=5
DEFAULT_MINIMUM_VIEWS=10000
DEFAULT_RESULT_LIMIT=30
